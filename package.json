{
  "name": "first-responder-analytics",
  "version": "1.0.0",
  "description": "First Responder Analytics Platform — AI-powered incident management and resource optimization",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cd dashboard && npm install && npm run build",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "ts-node src/db/migrate.ts",
    "seed": "ts-node src/db/seeds/seed.ts",
    "reset-db": "ts-node src/db/reset.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
