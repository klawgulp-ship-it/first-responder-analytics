# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/first_responder_analytics
DB_HOST=localhost
DB_PORT=5432
DB_NAME=first_responder_analytics
DB_USER=postgres
DB_PASSWORD=password

# API
PORT=3001
NODE_ENV=development

# JWT Auth
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=8h

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
